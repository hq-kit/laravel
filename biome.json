{
    "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
    "vcs": {
        "enabled": false,
        "clientKind": "git",
        "useIgnoreFile": false
    },
    "files": {
        "includes": [
            "resources/js/**/*.{tsx,ts,json}",
            "!resources/js/actions/**/*.{tsx,ts}",
            "!resources/js/routes/**/*.{tsx,ts}",
            "!resources/js/wayfinder/**/*.{tsx,ts}"
        ],
        "ignoreUnknown": false
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "performance": {
                "noImgElement": "off"
            },
            "style": {
                "noNonNullAssertion": "off",
                "noParameterAssign": "warn",
                "useImportType": "warn"
            },
            "complexity": {
                "useArrowFunction": "error",
                "noForEach": "off"
            },
            "a11y": {
                "noRedundantRoles": "off",
                "noSvgWithoutTitle": "off",
                "useValidAnchor": "off",
                "useSemanticElements": "off",
                "noPositiveTabindex": "off",
                "useAriaPropsForRole": "off",
                "useAriaPropsSupportedByRole": "off",
                "useFocusableInteractive": "off",
                "useKeyWithClickEvents": "off"
            },
            "correctness": {
                "noUnusedImports": { "level": "error", "fix": "safe" },
                "useExhaustiveDependencies": "off",
                "useHookAtTopLevel": "error",
                "noChildrenProp": "off"
            },
            "suspicious": {
                "noDocumentCookie": "off",
                "noExplicitAny": "off",
                "noArrayIndexKey": "off",
                "useIterableCallbackReturn": "off"
            },
            "security": {
                "noDangerouslySetInnerHtml": "off"
            },
            "nursery": {
                "useSortedClasses": {
                    "level": "error",
                    "fix": "safe",
                    "options": {
                        "attributes": ["classList"],
                        "functions": ["cn", "clsx", "tv", "twMerge", "twJoin"]
                    }
                }
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "arrowParentheses": "always",
            "bracketSameLine": false,
            "bracketSpacing": true,
            "jsxQuoteStyle": "single",
            "quoteProperties": "asNeeded",
            "semicolons": "asNeeded",
            "trailingCommas": "all",
            "indentWidth": 4
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
